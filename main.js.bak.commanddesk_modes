});

ipcMain.handle("config:reorderWebApps", async (_event, ids) => {
  const apps = await readWebAppsConfig();
  const map = new Map(apps.map(a => [a.id, a]));
  const reordered = ids.map(id => map.get(id)).filter(Boolean);
  await fs.writeFile(path.join(__dirname, "data", "webapps.json"), JSON.stringify(reordered, null, 2), "utf8");
  return reordered;
});

ipcMain.handle("webapp:launch", async (_event, { id, urlOverride }) => {
  if (!id) {
    throw new Error("Webapp id is required.");
  }

  const apps = await readWebAppsConfig();
  const appEntry = apps.find(app => app.id === id);

  if (!appEntry) {
    throw new Error(`Webapp not found: ${id}`);
  }

  const effectiveUrl = urlOverride || appEntry.url;

  const { binary, profile, flatpakId } = await getChromiumConfig();

  const args = [];

  // If running Chromium as a Flatpak, construct: flatpak run <id> [flags]
  if (flatpakId) {
    args.push("run", flatpakId);

    const effectiveProfile = appEntry.profile || profile;
    if (effectiveProfile) {
      args.push(`--profile=${effectiveProfile}`);
    }

    if (urlOverride) {
      args.push(urlOverride);
    } else if (appEntry.appId) {
      // Use Chromium app-id, matching how your KDE launchers work
      args.push(`--app-id=${appEntry.appId}`);
    } else if (appEntry.mode === "app" && appEntry.url) {
      args.push(`--app=${appEntry.url}`);
    } else if (appEntry.url) {
      args.push(appEntry.url);
    }
  } else {
    // Traditional binary mode (non-Flatpak Chromium/Chrome)
    const effectiveProfile = appEntry.profile || profile;
    if (effectiveProfile) {
      args.push(`--profile-directory=${effectiveProfile}`);
    }

    if (!urlOverride && appEntry.mode === "app" && effectiveUrl) {
      args.push(`--app=${effectiveUrl}`);
    } else if (!urlOverride && effectiveUrl) {
      args.push(effectiveUrl);
    } else if (urlOverride) {
      args.push(urlOverride);
    }
  }

  const child = spawn(binary, args, {
    detached: true,
    stdio: "ignore"
  });

  child.unref();

  return { launched: true, binary, args };
});
